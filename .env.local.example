# Supabase — found in your Supabase project under Settings > API.
# Copy this file to .env.local and fill in the real values.
# On Vercel, add the same three variables under Project Settings > Environment Variables.

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" public API key (safe to expose to the browser; protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service role key — SERVER-ONLY. Used by API route handlers.
# Never expose this to the browser and never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=

# The one admin user's email — SERVER-ONLY. Must exactly match the email of
# the user you created manually in Supabase (Authentication > Users).
# Only this account can access /admin.
ADMIN_EMAIL=

# Contact email included in the User-Agent header on requests to community
# map services (Overpass), per their acceptable-use policies. SERVER-ONLY.
APP_CONTACT_EMAIL=
